modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SR Screener UI"

[[workflows.workflow]]
name = "SR Screener UI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py sr-ui"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8501
externalPort = 3000

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "python main.py"]
