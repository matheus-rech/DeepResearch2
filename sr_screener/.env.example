# Copy this file to .env and fill in your values

# OpenAI API Key (required for Deep Research)
OPENAI_API_KEY=sk-................................

# MCP Server URL (default: http://localhost:8000/sse/)
# Change this if running MCP server on a different host/port
MCP_URL=http://localhost:8000/sse/

# Database URL (automatically set by Replit if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional: Vector Store ID for OpenAI Vector Storage integration
# VECTOR_STORE_ID=vs_...