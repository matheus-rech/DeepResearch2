# Copy this file to .env and fill in your values

# OpenAI API Key (required for Deep Research and embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Secondary OpenAI API Key (optional, for load balancing or different models)
OPENAI_API_KEY_2=your_secondary_openai_api_key_here

# Vector Store ID for OpenAI Vector Storage integration (required for vector store mode)
VECTOR_STORE_ID=your_vector_store_id_here

# Database URL (optional, defaults to SQLite if not provided)
# For PostgreSQL: postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://user:password@localhost:5432/deepresearch

# MCP Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Streamlit UI Configuration  
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8000

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
