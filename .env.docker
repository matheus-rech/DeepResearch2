# Docker environment configuration for DeepResearch2
# Copy this file to .env and fill in your values

# Required
OPENAI_API_KEY=your_openai_api_key_here

# Optional
OPENAI_API_KEY_2=your_secondary_openai_api_key_here
VECTOR_STORE_ID=your_vector_store_id_here

# Database configuration
# Uncomment to use PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://deepresearch:password@postgres:5432/deepresearch

# Server configuration
MCP_HOST=0.0.0.0
MCP_PORT=8001
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8000

# External access configuration
# Set these for production deployment
EXTERNAL_HOST=your_public_hostname_here
EXTERNAL_PORT=443
EXTERNAL_PROTOCOL=https

# For PostgreSQL service (when using docker-compose with postgres profile)
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Logging
LOG_LEVEL=INFO
