# Docker environment configuration for DeepResearch2

# OpenAI API Keys - Required for Deep Research API
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_API_KEY_2=

# Vector Store ID for Deep Research API
VECTOR_STORE_ID=${VECTOR_STORE_ID}

# Database configuration
DATABASE_URL=sqlite:///citations.db
# Uncomment to use PostgreSQL instead of SQLite
# DATABASE_URL=postgresql://deepresearch:password@postgres:5432/deepresearch

# Server configuration
MCP_HOST=0.0.0.0
MCP_PORT=8001
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8000

# External access configuration
# These are set automatically by docker-deploy.sh
EXTERNAL_HOST=172.16.5.2
EXTERNAL_PORT=8001
EXTERNAL_PROTOCOL=http

# For PostgreSQL service (when using docker-compose with postgres profile)
POSTGRES_PASSWORD=strong_password_change_me

# Logging
LOG_LEVEL=INFO

# Container Flag
DOCKER_CONTAINER=true
